# ──────────────────────────────────────────────
# Agenstin 환경변수 설정
# 이 파일을 복사하여 .env를 만들고 실제 값을 채워주세요.
# cp .env.example .env
# ──────────────────────────────────────────────

# Anthropic API (Sonnet 라우터 + Claude CLI 공통)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Slack (Slack 봇 모드 사용 시 필요)
# SLACK_BOT_TOKEN: OAuth & Permissions > Bot User OAuth Token
# SLACK_APP_TOKEN: Basic Information > App-Level Tokens (connections:write)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# 인시던트 분석 (서브프로젝트 코드베이스 루트 경로)
# 인시던트 발생 시 이 경로의 소스코드를 Claude Opus로 분석합니다.
INCIDENT_WORKSPACE=/path/to/your-workspace
